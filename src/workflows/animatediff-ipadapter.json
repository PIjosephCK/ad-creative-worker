{
  "1": {
    "class_type": "CheckpointLoaderSimple",
    "inputs": {
      "ckpt_name": "juggernautXL_v10.safetensors"
    }
  },
  "2": {
    "class_type": "CLIPTextEncode",
    "inputs": {
      "text": "{{PROMPT}}",
      "clip": ["1", 1]
    }
  },
  "3": {
    "class_type": "CLIPTextEncode",
    "inputs": {
      "text": "{{NEGATIVE_PROMPT}}",
      "clip": ["1", 1]
    }
  },
  "4": {
    "class_type": "LoadImage",
    "inputs": {
      "image": "{{REFERENCE_IMAGE}}"
    }
  },
  "5": {
    "class_type": "IPAdapterUnifiedLoader",
    "inputs": {
      "model": ["1", 0],
      "preset": "PLUS (high strength)"
    }
  },
  "7": {
    "class_type": "IPAdapter",
    "inputs": {
      "ipadapter": ["5", 1],
      "model": ["5", 0],
      "image": ["4", 0],
      "weight": {{IPADAPTER_WEIGHT}},
      "start_at": 0.0,
      "end_at": 1.0,
      "weight_type": "standard"
    }
  },
  "10": {
    "class_type": "ADE_LoadAnimateDiffModel",
    "inputs": {
      "model_name": "mm_sdxl_v10_beta.ckpt"
    }
  },
  "11": {
    "class_type": "ADE_ApplyAnimateDiffModelSimple",
    "inputs": {
      "motion_model": ["10", 0]
    }
  },
  "12": {
    "class_type": "ADE_StandardUniformContextOptions",
    "inputs": {
      "context_length": 16,
      "context_stride": 1,
      "context_overlap": 4
    }
  },
  "13": {
    "class_type": "ADE_UseEvolvedSampling",
    "inputs": {
      "model": ["7", 0],
      "beta_schedule": "linear (AnimateDiff-SDXL)",
      "m_models": ["11", 0],
      "context_options": ["12", 0]
    }
  },
  "15": {
    "class_type": "EmptyLatentImage",
    "inputs": {
      "width": {{WIDTH}},
      "height": {{HEIGHT}},
      "batch_size": {{FRAMES}}
    }
  },
  "6": {
    "class_type": "KSampler",
    "inputs": {
      "seed": {{SEED}},
      "steps": {{STEPS}},
      "cfg": {{CFG}},
      "sampler_name": "dpmpp_2m",
      "scheduler": "karras",
      "denoise": 1.0,
      "model": ["13", 0],
      "positive": ["2", 0],
      "negative": ["3", 0],
      "latent_image": ["15", 0]
    }
  },
  "8": {
    "class_type": "VAEDecode",
    "inputs": {
      "samples": ["6", 0],
      "vae": ["1", 2]
    }
  },
  "9": {
    "class_type": "ADE_AnimateDiffCombine",
    "inputs": {
      "images": ["8", 0],
      "frame_rate": {{FPS}},
      "loop_count": 0,
      "filename_prefix": "{{FILENAME_PREFIX}}",
      "format": "image/webp",
      "pingpong": false,
      "save_image": true
    }
  }
}
