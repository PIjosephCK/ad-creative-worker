{
  "1": {
    "class_type": "CheckpointLoaderSimple",
    "inputs": {
      "ckpt_name": "juggernautXL_v10.safetensors"
    }
  },
  "2": {
    "class_type": "CLIPTextEncode",
    "inputs": {
      "text": "{{PROMPT}}",
      "clip": ["1", 1]
    }
  },
  "3": {
    "class_type": "CLIPTextEncode",
    "inputs": {
      "text": "{{NEGATIVE_PROMPT}}",
      "clip": ["1", 1]
    }
  },
  "4": {
    "class_type": "LoadImage",
    "inputs": {
      "image": "{{REFERENCE_IMAGE}}"
    }
  },
  "5": {
    "class_type": "IPAdapterUnifiedLoader",
    "inputs": {
      "model": ["1", 0],
      "preset": "PLUS FACE (portraits)"
    }
  },
  "7": {
    "class_type": "IPAdapter",
    "inputs": {
      "ipadapter": ["5", 1],
      "model": ["5", 0],
      "image": ["4", 0],
      "weight": {{IPADAPTER_WEIGHT}},
      "start_at": 0.0,
      "end_at": 1.0,
      "weight_type": "standard"
    }
  },
  "20": {
    "class_type": "LoadImage",
    "inputs": {
      "image": "{{STYLE_IMAGE}}"
    }
  },
  "21": {
    "class_type": "IPAdapterUnifiedLoader",
    "inputs": {
      "model": ["7", 0],
      "preset": "PLUS (high strength)"
    }
  },
  "22": {
    "class_type": "IPAdapter",
    "inputs": {
      "ipadapter": ["21", 1],
      "model": ["21", 0],
      "image": ["20", 0],
      "weight": {{STYLE_WEIGHT}},
      "start_at": 0.0,
      "end_at": 1.0,
      "weight_type": "style transfer"
    }
  },
  "8": {
    "class_type": "EmptyLatentImage",
    "inputs": {
      "width": {{WIDTH}},
      "height": {{HEIGHT}},
      "batch_size": 1
    }
  },
  "9": {
    "class_type": "KSampler",
    "inputs": {
      "seed": {{SEED}},
      "steps": {{STEPS}},
      "cfg": {{CFG}},
      "sampler_name": "dpm++_2m",
      "scheduler": "karras",
      "denoise": 1.0,
      "model": ["22", 0],
      "positive": ["2", 0],
      "negative": ["3", 0],
      "latent_image": ["8", 0]
    }
  },
  "10": {
    "class_type": "VAEDecode",
    "inputs": {
      "samples": ["9", 0],
      "vae": ["1", 2]
    }
  },
  "11": {
    "class_type": "SaveImage",
    "inputs": {
      "filename_prefix": "scene_style",
      "images": ["10", 0]
    }
  }
}
