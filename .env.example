# === Database ===
DATABASE_URL="file:./data/worker.db"

# === Ollama (Qwen) ===
OLLAMA_BASE_URL="http://localhost:11434/v1"
OLLAMA_MODEL="qwen3:8b"
OLLAMA_VL_MODEL="minicpm-v"
OLLAMA_KEEP_ALIVE="0"

# === ComfyUI ===
COMFYUI_URL="http://localhost:8888"
COMFYUI_WS_URL="ws://localhost:8888/ws"
COMFYUI_INPUT_DIR="/opt/comfyui/input"
COMFYUI_OUTPUT_DIR="/opt/comfyui/output"

# === Worker Server ===
PORT=3000
NODE_ENV="development"
OUTPUT_DIR="./output"
BASE_URL="http://localhost:3000"
